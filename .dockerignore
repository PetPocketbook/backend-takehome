.git
.gitignore
.gitattributes

# Dependencies and build artifacts
node_modules/
frontend/node_modules/
frontend/dist/
backend/public/frontend/
backend/.bundle/

# Local databases and runtime files
backend/db/*.sqlite3
backend/db/*.sqlite3-*
backend/log/*
backend/tmp/*
!backend/log/.keep
!backend/tmp/.keep
!backend/tmp/pids/
!backend/tmp/pids/.keep

# Secrets and local env
.env
.env.*
backend/config/master.key

# Docs and IDE
*.md
.vscode/
.idea/
