#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

cd "$ROOT/backend"
bundle install
bin/rails db:prepare

cd "$ROOT"
if [ ! -d node_modules ] || [ ! -e node_modules/.bin/concurrently ]; then
  npm install
fi

if [ ! -d frontend/node_modules ]; then
  npm run frontend:install
fi

exec npm run dev
